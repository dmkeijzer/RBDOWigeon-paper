#!/bin/bash
#
#PBS -N MyPythonJob  # Job name
#PBS -l nodes=1:ppn=1  # Number of nodes and CPUs per node
#PBS -l mem=2gb  # Memory requirement
#PBS -l walltime=20:00:00  # Maximum wall-clock time
#
# Set the working directory
cd $PBS_O_WORKDIR
module load devtoolset/8
module load intel/oneapi_2022u1
export PYTHONPATH=$PYTHONPATH:~/wigeon_proj/code_wigeon
#
# Load any necessary modules (if required by your cluster)
/opt/ud/intel_oneapi_2022u1/intelpython/python3.9/bin/python3 -m pip install openmdao
#
LOG_FILE="/home/dmkeijzer/wigeon_proj/code_wigeon/scripts/13_July_log_21.59_baseline.log"
#
#export PYTHONPATH="/path/to/your/additional/module:/another/path"
# Run the Python script
/opt/ud/intel_oneapi_2022u1/intelpython/python3.9/bin/python3 Optimization_baseline.py > "$LOG_FILE" 2>&1
